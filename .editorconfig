# EditorConfig pins per-editor settings so VSCode / PyCharm / Vim / Notepad++
# honour the same conventions as the .gitattributes contract.
#
# https://editorconfig.org -- supported natively by VSCode, JetBrains, Vim
# (with editorconfig-vim), Sublime, and most modern editors.
#
# CRLF EVERYWHERE. The repo currently has no `.sh`, `.bash`, `.zsh`, or
# `Makefile`. If any are added in future, override `end_of_line = lf` for
# them explicitly -- POSIX bash and POSIX make break on CRLF.

root = true

# Default: every text file in the repo
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python
[*.py]
indent_size = 4
max_line_length = 100

# JSON / YAML / TOML config
[*.{json,yaml,yml,toml}]
indent_size = 2

# Notebooks: JSON shape; do not trim trailing whitespace inside source cells
# (Jupyter formats outputs with trailing whitespace at line end in some kernels)
[*.ipynb]
indent_size = 1
trim_trailing_whitespace = false

# Markdown: preserve trailing two-space line breaks (Markdown soft-break syntax)
[*.{md,markdown}]
trim_trailing_whitespace = false

# Hidden config files at repo root
[.{gitignore,gitattributes,editorconfig,flake8}]
indent_size = 4
